generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompatibilityLevel {
  ENCAIXE_PERFEITO
  ADAPTACAO_SIMPLES
  ADAPTACAO_COMPLEXA
}

enum SuggestionStatus {
  PENDENTE
  APROVADA
  REJEITADA
}

model Part {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  compatibleParts CompatiblePart[]

  @@map("parts")
}

model CompatiblePart {
  id                 String             @id @default(cuid())
  name               String
  brand              String?
  partNumber         String?
  price              Float?
  purchaseLink       String?
  imageUrl           String?
  compatibilityLevel CompatibilityLevel
  adaptationText     String?
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  videos          VideoReference[]
  linkSuggestions LinkSuggestion[]

  @@map("compatible_parts")
}

model VideoReference {
  id               String @id @default(cuid())
  url              String
  platform         String
  title            String?
  compatiblePartId String

  compatiblePart CompatiblePart @relation(fields: [compatiblePartId], references: [id], onDelete: Cascade)

  @@map("video_references")
}

model AdSpace {
  id          String   @id @default(cuid())
  slot        String   @unique // "top" | "sidebar" | "inline"
  label       String
  description String?
  active      Boolean  @default(false)
  adCode      String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ad_spaces")
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?  @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_configs")
}

model AffiliateConfig {
  id        String   @id @default(cuid())
  platform  String   @unique // "amazon" | "mercadolivre" | "shopee" | "aliexpress" | "magalu"
  active    Boolean  @default(false)
  value     String?  // tag/ID para param ou URL base para redirect
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("affiliate_configs")
}

model LinkSuggestion {
  id               String           @id @default(cuid())
  compatiblePartId String
  compatiblePart   CompatiblePart   @relation(fields: [compatiblePartId], references: [id], onDelete: Cascade)
  purchaseLink     String?
  videoLinks       String?          @db.Text // URLs separadas por \n
  submitterEmail   String?
  notes            String?
  status           SuggestionStatus @default(PENDENTE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("link_suggestions")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

model Suggestion {
  id                 String             @id @default(cuid())
  partName           String
  compatiblePartName String
  brand              String?
  purchaseLink       String
  compatibilityLevel CompatibilityLevel
  adaptationText     String?
  videoLinks         String?
  submitterEmail     String?
  status             SuggestionStatus   @default(PENDENTE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("suggestions")
}
